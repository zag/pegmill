{
  "name": "pegmill",
  "version": "0.1.1",
  "description": "WASM-native PEG parser generator",
  "keywords": [
    "parser generator",
    "PEG",
    "WebAssembly",
    "WASM",
    "parametric",
    "generics",
    "grammar-templates",
    "rule-templates",
    "generic-rules",
    "pegjs",
    "peggy"
  ],
  "homepage": "https://github.com/zag/pegmill",
  "bugs": { "url": "https://github.com/zag/pegmill/issues" },
  "license": "Apache-2.0",
  "author": "Aliaksandr Zahatski",
  "files": [
    "bin/pegmill",
    "examples/",
    "lib/**/*.js",
    "NOTICE.md"
  ],
  "main": "lib/peg",
  "bin": "bin/pegmill",
  "repository": { "type": "git", "url": "https://github.com/zag/pegmill.git" },
  "scripts": {
    "test": "npm run lint && npm run test:spec",
    "test:spec": "node_modules/.bin/jasmine",
    "lint": "node_modules/.bin/eslint lib/**/*.js \"spec/**/*.js\" --ignore-pattern spec/vendor/ benchmark/*.js benchmark/run bin/pegmill",
    "build": "node scripts/build-browser.js",
    "build:parser": "node scripts/build-parser.js",
    "clean": "node -e \"require('fs').rmSync('browser',{recursive:true,force:true})\"",
    "serve:spec": "node_modules/.bin/http-server",
    "benchmark": "benchmark/run"
  },
  "devDependencies": {
    "browserify": "13.1.0",
    "eslint": "2.13.1",
    "http-server": "0.9.0",
    "jasmine-node": "1.14.5",
    "uglify-js": "2.7.0"
  },
  "engines": {
    "node": ">=14"
  }
}
